<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Teardrop shape: rounded top, comes to a point at the bottom.
        Centered at (54, 50), width ~44, height ~54.
        The cubic bezier curves form a smooth teardrop.
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M54,20
            C54,20 76,36 76,52
            C76,64.15 66.15,74 54,74
            C41.85,74 32,64.15 32,52
            C32,36 54,20 54,20
            Z" />

    <!--
        ECG / heart-rate line running horizontally across the middle of the drop.
        Baseline y=52 (center of the teardrop).
        Sequence: flat → small bump up → sharp spike up → sharp spike down → recovery → flat
    -->
    <path
        android:strokeColor="#5C8BE0"
        android:strokeWidth="3.2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="
            M36,52
            L43,52
            L46,48
            L48,52
            L50,52
            L52,40
            L55,66
            L57,52
            L60,52
            L62,56
            L64,52
            L72,52" />

</vector>
