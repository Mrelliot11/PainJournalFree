<?xml version="1.0" encoding="utf-8"?>
<!-- Controls cloud backup and device-to-device transfer for API 31+ -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="pain_database" />
        <exclude domain="database" path="pain_database-shm" />
        <exclude domain="database" path="pain_database-wal" />
        <exclude domain="sharedpref" path="custom_options.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="pain_database" />
        <exclude domain="database" path="pain_database-shm" />
        <exclude domain="database" path="pain_database-wal" />
        <exclude domain="sharedpref" path="custom_options.xml" />
    </device-transfer>
</data-extraction-rules>
